# Sample Terraform variables file
# Copy this to terraform.tfvars and fill in your values

# AWS Configuration
aws_region    = "us-east-1"
environment   = "production"
project_name  = "payintelli"

# Database Configuration
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_name              = "payintelli"
db_username          = "payintelli_admin"
db_password          = "your-secure-password-here"

# Cognito Configuration
cognito_pool_name   = "payintelli-users"
cognito_client_name = "payintelli-app"

# S3 Configuration
materials_bucket_name = "payintelli-materials"

# Lambda Configuration
lambda_timeout     = 30
lambda_memory_size = 256
python_runtime     = "python3.12"

# VPC Configuration (required)
vpc_id              = "vpc-xxxxxxxx"
private_subnet_1_id = "subnet-xxxxxxxx"
private_subnet_2_id = "subnet-xxxxxxxx"
vpc_cidr           = "10.0.0.0/16"
